# ==================== 虚拟环境 venv 核心 ====================
# 通用虚拟环境文件夹名：venv / env / ast_venv / .venv
venv/
env/
.venv/
ast_venv/
*/venv/
*/env/
*/.venv/
# 虚拟环境配置临时文件
pyvenv.cfg

# ==================== Python 缓存文件 ====================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ==================== Pytest / 测试缓存 ====================
.pytest_cache/
.coverage
htmlcov/
nosetests.xml
coverage.xml
*.junit.xml

# ==================== 日志、运行输出 ====================
*.log
logs/
*.out
*.err

# ==================== Jupyter Notebook ====================
.ipynb_checkpoints/
*.ipynb
# 如果想保留笔记就删掉上面一行，只屏蔽缓存

# ==================== 系统/IDE 文件 ====================
# Windows
Thumbs.db
.DS_Store
# VSCode
.vscode/
*.swp
*.swo
# PyCharm
.idea/
*.iml
*.iws
*.prj
